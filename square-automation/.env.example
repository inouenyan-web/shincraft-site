# square-automation 環境変数の控え（項目名のみ。実値はGitに保存しない）
# 実値は Claude Code Web 環境の「環境変数」設定に登録すること。

# 必須: Catalog API トークン（スコープ ITEMS_READ + ITEMS_WRITE）
SQUARE_ACCESS_TOKEN=

# 任意: prod（既定）/ sandbox
SQUARE_ENV=prod

# 任意: 指定時のみ Square-Version ヘッダを送出（例: 2024-12-18）
SQUARE_VERSION=

# 任意: 将来のロケーション別操作用（本スクリプトでは未使用）
SQUARE_LOCATION_ID=
