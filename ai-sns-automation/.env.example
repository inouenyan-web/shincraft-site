# 秘密情報はここに「実値」を書かない。項目名の控えのみ。
# 実値は Claude Code Web環境の「環境変数」設定に登録する（GitHubには保存しない）。
# 詳細は SETUP_SECRETS.md を参照。

# --- X (旧Twitter) 投稿用: OAuth 1.0a ユーザーコンテキスト ---
X_API_KEY=
X_API_SECRET=
X_ACCESS_TOKEN=
X_ACCESS_SECRET=

# --- note -> X クロスポスト ---
NOTE_USERNAME=                 # note.com/<ここ>/rss のユーザー名
# NOTE_X_TEMPLATE="新しい記事を投稿しました📝\n{title}\n{link}"

# --- Google Sheets 台帳 (Apps Script Web App 経由) ---
GAS_WEBAPP_URL=                # ウェブアプリのデプロイURL
GAS_SHARED_TOKEN=              # Apps Scriptのスクリプトプロパティ SHARED_TOKEN と一致させる

# --- 任意: 投稿時に生成画像URLの添付を試みる場合 ---
# ATTACH_IMAGE=1

# --- 背景透過（@imgly/background-removal-node：APIキー不要）---
DRIVE_NOBG_FOLDER_ID=           # Google Drive「02_背景透過済み」フォルダのID

# --- 参考: 旧構成で使用（現在はフォールバック扱い） ---
# OPENAI_API_KEY=
# BUFFER_API_KEY=
