# Do NOT commit real secrets. This file is placeholders only.
#
# 秘密情報の実体は GitHub に置かない。
# - Apps Script 側で使う値は「スクリプトのプロパティ（PropertiesService）」に保存する
# - ローカル/CI で使う値はこのファイルをコピーした .env（gitignore対象）に入れる

# --- OpenAI / Buffer / Yoom / Google ---
OPENAI_API_KEY=your_openai_api_key_here
BUFFER_API_KEY=your_buffer_api_key_here
YOOM_CREDENTIAL_REF=your_yoom_secret_reference_here
GOOGLE_OAUTH_TOKEN=do_not_store_token_in_github

# --- GAS Webhook 中継 ---
# Apps Script を「ウェブアプリ」としてデプロイしたときに発行される URL
GAS_WEBAPP_URL=https://script.google.com/macros/s/xxxxxxxxxxxx/exec
# Webhook を保護する共有トークン。Yoom の POST と GAS の Script Property を一致させる
# （GAS 側は PropertiesService のプロパティ名 SHARED_TOKEN に同じ値を設定する）
GAS_SHARED_TOKEN=your_shared_token_here

# --- X (Twitter) API ---
X_API_KEY=your_x_api_key_here
X_API_SECRET=your_x_api_secret_here
X_BEARER_TOKEN=your_x_bearer_token_here
X_ACCESS_TOKEN=your_x_access_token_here
X_ACCESS_TOKEN_SECRET=your_x_access_token_secret_here

# --- note ---
# note の公開ユーザー名（例: oshin_2026 → https://note.com/oshin_2026）
NOTE_USERNAME=your_note_username_here
